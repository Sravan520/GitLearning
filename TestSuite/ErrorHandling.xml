<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Suite" parallel="tests">
<groups>
<run>
<include name="ErrorHandling"></include>
</run>

</groups>

<listeners>
<listener  class-name= "TestComponents.Listeners"/>
</listeners>

  <test thread-count="5" name="Submit Order Test">
    <classes>
      <class name="sravanacademy.SubmitOrderTest"/>
      </classes>
  </test> <!-- Test -->
  
  <test thread-count="5" name="Error Validations Test">
    <classes>
      <class name="sravanacademy.ErrorValidation"/>
    </classes>
  </test> <!-- Test -->
  
</suite> <!-- Suite -->
